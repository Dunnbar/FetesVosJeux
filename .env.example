# Copier en .env (local) ou définir comme env vars Vercel (prod).
# Voir DEPLOY.md pour le détail du setup.

# ============ Base de données (Postgres) ============
# Local dev : utilise un branch Neon dédié, ou un Postgres Docker local.
# Prod : auto-injecté par l'intégration Vercel ↔ Neon.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Neon expose une URL non-pooled séparée pour les migrations (optionnel,
# fallback sur DATABASE_URL si non défini).
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ============ Storage des images uploadées ============
# Vercel Blob — auto-injecté par l'intégration Vercel ↔ Blob en prod.
# En dev local, laisser vide pour utiliser /public/uploads/ comme fallback.
BLOB_READ_WRITE_TOKEN=""

# ============ Email (Resend) ============
RESEND_API_KEY="re_..."
# Le from doit être un domaine vérifié dans Resend.
# Pour tester rapidement, utiliser onboarding@resend.dev (limité à
# l'adresse du compte Resend).
EMAIL_FROM="Qui S'y Gratte <onboarding@resend.dev>"

# ============ URL publique ============
# Utilisée dans les emails et les liens partagés.
# Local : http://localhost:3000
# Prod  : ton vrai domaine, ex: https://quisygratte.fr
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============ Stripe (pas encore branché) ============
# À renseigner quand on implémentera le paiement.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
