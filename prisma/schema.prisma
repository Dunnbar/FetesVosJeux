// Fêtes Vos Jeux — schéma Prisma
// Postgres (Neon en prod, branch dev pour le local — voir DEPLOY.md).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Connexion directe (non-pooled) utilisée par les migrations.
  // Nom aligné sur ce qu'injecte l'intégration Vercel↔Neon (auto-injecté
  // côté Vercel). En local, voir .env qui définit la même variable.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

/// Une carte à gratter = ce que l'acheteur crée et envoie.
/// `code` est un identifiant court et URL-safe utilisé dans le lien
/// public partagé au destinataire : /g/<code>
///
/// La structure du produit :
///   1. L'acheteur uploade une COUVERTURE (souvent une photo : couple,
///      famille, portrait…) qui sera l'image grattable au-dessus.
///   2. Il choisit ce qui apparaît une fois la couverture grattée :
///      - soit une autre image qu'il uploade (`annonceMode = "image"`)
///      - soit une annonce texte selon un template (mariage / naissance /
///        anniversaire…) dont il remplit les champs (`annonceMode = "text"`)
model Scratch {
  code String @id // ex: "K7M3PQ8X42"

  // Mécanique d'interaction pour révéler l'annonce.
  // Valeurs : "scratch" | "polaroid" | "envelope" | "champagne" | "ink"
  revealMechanic String @default("scratch")

  // L'image (cover) — toujours présente, son usage varie selon la mécanique :
  //   - scratch     : photo grattable au-dessus de l'annonce
  //   - polaroid    : photo qui se "développe" dans le cadre Polaroid
  //   - envelope    : photo imprimée sur la carte qui sort de l'enveloppe
  //   - champagne   : photo sur l'étiquette de la bouteille
  //   - ink         : photo / motif sous le parchemin
  coverImagePath String // ex: "/uploads/abc.jpg"

  // Cadrage de la cover dans le carré (éditeur "déplacer/zoomer").
  // Point focal en 0–1 (0.5/0.5 = centré) + facteur de zoom (1 = cover de base).
  coverPosX Float @default(0.5)
  coverPosY Float @default(0.5)
  coverZoom Float @default(1)

  // Ticket à gratter uniquement — sens du grattage :
  //   false (défaut) : on gratte la photo, ça révèle le texte
  //   true           : on gratte le texte, ça révèle la photo
  scratchTextOnTop Boolean @default(false)

  // L'annonce révélée en dessous : image OU texte selon un template.
  annonceMode      String  @default("text") // "text" | "image"
  annonceImagePath String? // utilisé si annonceMode = "image"

  // Si annonceMode = "text" :
  annonceTemplate String? // "mariage" | "naissance" | "anniversaire" | ...
  // Champs génériques remplis selon le template. Le mapping est porté
  // par le composant AnnonceCard côté front.
  annonceTitle    String? // ex: "Sarah & Tom"
  annonceSubtitle String? // ex: "se marient"
  annonceBody     String? // ex: "Le 15 juin 2026 à Étretat — RSVP avant le 1er mai"

  // Options payantes ajoutées au prix de base.
  // Affichés/joués sur /g/[code] uniquement si activés.
  withFireworks Boolean @default(false) // feux d'artifice CSS au reveal
  withSound     Boolean @default(false) // mini-fanfare Web Audio API au reveal

  // Acheteur
  buyerName  String?
  buyerEmail String?

  // Paiement
  amountCents           Int     @default(500)
  status                String  @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  stripeSessionId       String? @unique
  stripePaymentIntentId String? @unique

  // Si la carte a été débloquée avec un code cadeau (offert) plutôt que
  // payée via Stripe, on garde la trace du code utilisé pour le suivi.
  giftCode String?

  // Commande multi-formats : quand l'acheteur prend 2 ou 3 formats, les
  // cartes (une par mécanique) partagent ce groupId et sont payées ensemble.
  // null = carte seule (1 format), comportement historique inchangé.
  // Le montant total de la commande est porté par la carte "lead" du groupe.
  groupId String?

  @@index([groupId])

  // Analytics légères
  scratchedAt DateTime? // 1ère fois où le destinataire a déclenché la révélation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Code cadeau à usage unique, généré par l'admin (cf. `npm run codes:gen`)
/// et distribué à la main. Saisi sur la page d'aperçu, il débloque la carte
/// gratuitement (status PAID) sans passer par Stripe, puis est consommé.
model PromoCode {
  code String @id // ex: "K7M3PQ8X42" — même alphabet que les cartes

  used   Boolean   @default(false) // consommé une fois utilisé
  usedAt DateTime?
  // Code de la carte qui a consommé ce code cadeau (pour le suivi).
  usedByScratchCode String?

  // Note libre pour le suivi côté admin (ex: "cadeau Marie", "jeu concours").
  note String?

  createdAt DateTime @default(now())
}
